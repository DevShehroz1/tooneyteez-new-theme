<style>
  #shopify-section-{{ section.id }} {
    padding: 60px 0;
    background-color: #ffffff;
  }

  #shopify-section-{{ section.id }} .shop-by-category-wrapper {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #shopify-section-{{ section.id }} .section-title {
    text-align: center;
    font-size: 32px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
    color: #000000;
  }

  #shopify-section-{{ section.id }} .section-title-line {
    width: 80px;
    height: 2px;
    background-color: #000000;
    margin: 0 auto 30px;
  }

  #shopify-section-{{ section.id }} .category-tabs {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 30px;
    margin-bottom: 40px;
    padding: 0 20px;
  }

  #shopify-section-{{ section.id }} .category-tab {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: color 0.3s ease;
    background: none;
    border: none;
    padding: 0;
    color: #999999;
  }

  #shopify-section-{{ section.id }} .category-tab.active {
    color: #000000;
  }

  #shopify-section-{{ section.id }} .category-tab:hover {
    color: #000000;
  }

  #shopify-section-{{ section.id }} .category-content {
    display: none;
  }

  #shopify-section-{{ section.id }} .category-content.active {
    display: block;
  }

  #shopify-section-{{ section.id }} .collections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    padding: 0 20px;
  }

  #shopify-section-{{ section.id }} .collection-item {
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .collection-item:hover {
    transform: translateY(-5px);
  }

  #shopify-section-{{ section.id }} .collection-image {
    width: 100%;
    min-height: 400px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    margin-bottom: 15px;
    background-color: #f5f5f5;
    border-radius: 4px;
  }

  #shopify-section-{{ section.id }} .collection-title {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #000000;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      padding: 40px 0;
    }

    #shopify-section-{{ section.id }} .section-title {
      font-size: 24px;
    }

    #shopify-section-{{ section.id }} .category-tabs {
      padding: 0 10px;
      gap: 20px;
      margin-bottom: 30px;
    }

    #shopify-section-{{ section.id }} .collections-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      padding: 0 10px;
    }

    #shopify-section-{{ section.id }} .collection-image {
      min-height: 250px;
    }

    #shopify-section-{{ section.id }} .collection-title {
      font-size: 12px;
    }
  }

  @media screen and (min-width: 769px) and (max-width: 1024px) {
    #shopify-section-{{ section.id }} .collections-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<div class="shop-by-category-wrapper">
  {% if section.settings.title != blank %}
    <h2 class="section-title">{{ section.settings.title }}</h2>
    <div class="section-title-line"></div>
  {% endif %}

  <div class="category-tabs">
    <button class="category-tab active" data-tab="men">MEN</button>
    <button class="category-tab" data-tab="women">WOMEN</button>
  </div>

  <!-- Men Collections -->
  <div class="category-content active" data-content="men">
    <div class="collections-grid">
      {%- for block in section.blocks -%}
        {%- if block.settings.gender == 'men' -%}
          {%- assign collection_item = collections[block.settings.collection] -%}
          {%- if collection_item != blank -%}
            <a href="{{ collection_item.url }}" class="collection-item" {{ block.shopify_attributes }}>
              {%- if block.settings.custom_image != blank -%}
                <img 
                  src="{{ block.settings.custom_image | image_url: width: 600 }}"
                  alt="{{ block.settings.custom_title | default: collection_item.title }}"
                  class="collection-image"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {%- elsif collection_item.featured_image != blank -%}
                <img 
                  src="{{ collection_item.featured_image | image_url: width: 600 }}"
                  alt="{{ collection_item.title }}"
                  class="collection-image"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'collection-image' }}
              {%- endif -%}
              <h3 class="collection-title">
                {{ block.settings.custom_title | default: collection_item.title }}
              </h3>
            </a>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Women Collections -->
  <div class="category-content" data-content="women">
    <div class="collections-grid">
      {%- for block in section.blocks -%}
        {%- if block.settings.gender == 'women' -%}
          {%- assign collection_item = collections[block.settings.collection] -%}
          {%- if collection_item != blank -%}
            <a href="{{ collection_item.url }}" class="collection-item" {{ block.shopify_attributes }}>
              {%- if block.settings.custom_image != blank -%}
                <img 
                  src="{{ block.settings.custom_image | image_url: width: 600 }}"
                  alt="{{ block.settings.custom_title | default: collection_item.title }}"
                  class="collection-image"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {%- elsif collection_item.featured_image != blank -%}
                <img 
                  src="{{ collection_item.featured_image | image_url: width: 600 }}"
                  alt="{{ collection_item.title }}"
                  class="collection-image"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'collection-image' }}
              {%- endif -%}
              <h3 class="collection-title">
                {{ block.settings.custom_title | default: collection_item.title }}
              </h3>
            </a>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const tabs = document.querySelectorAll(`#shopify-section-${sectionId} .category-tab`);
    const contents = document.querySelectorAll(`#shopify-section-${sectionId} .category-content`);

    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const targetTab = this.getAttribute('data-tab');
        
        // Remove active class from all tabs and contents
        tabs.forEach(t => t.classList.remove('active'));
        contents.forEach(c => c.classList.remove('active'));
        
        // Add active class to clicked tab and corresponding content
        this.classList.add('active');
        const targetContent = document.querySelector(`#shopify-section-${sectionId} .category-content[data-content="${targetTab}"]`);
        if (targetContent) {
          targetContent.classList.add('active');
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Shop by Category",
  "tag": "section",
  "class": "shop-by-category-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "SHOP BY CATEGORY"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "select",
          "id": "gender",
          "label": "Gender",
          "options": [
            {
              "value": "men",
              "label": "Men"
            },
            {
              "value": "women",
              "label": "Women"
            }
          ],
          "default": "men"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title",
          "info": "Leave blank to use collection title"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image",
          "info": "Leave blank to use collection featured image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "gender": "men"
          }
        },
        {
          "type": "collection",
          "settings": {
            "gender": "men"
          }
        },
        {
          "type": "collection",
          "settings": {
            "gender": "men"
          }
        },
        {
          "type": "collection",
          "settings": {
            "gender": "women"
          }
        },
        {
          "type": "collection",
          "settings": {
            "gender": "women"
          }
        },
        {
          "type": "collection",
          "settings": {
            "gender": "women"
          }
        }
      ]
    }
  ]
}
{% endschema %}

