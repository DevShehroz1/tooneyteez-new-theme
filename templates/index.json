    "custom_liquid_xDXVJn": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "Custom Liquid",
      "settings": {
        "custom_liquid": "{%- liquid\n  assign message1 = \"15 days Money back Guarantee\"\n  assign message2 = \"Free Shipping on Order Above 2999\"\n  assign message3 = \"Export Quality Clothing\"\n-%}\n\n<style>\n  .promo-bar {\n    width: 100%;\n    background-color: #000000;\n    color: #ffffff;\n    padding: 12px 20px;\n    text-align: center;\n    font-size: 12px;\n    font-weight: 500;\n    letter-spacing: 0.5px;\n    text-transform: uppercase;\n    line-height: 1.4;\n    overflow: hidden;\n    position: relative;\n  }\n\n  .promo-bar-desktop {\n    display: flex;\n    justify-content: space-around;\n    align-items: center;\n    gap: 20px;\n  }\n\n  .promo-bar-desktop .promo-message {\n    flex: 1;\n    white-space: nowrap;\n  }\n\n  .promo-bar-mobile {\n    display: none;\n    position: relative;\n    min-height: 20px;\n  }\n\n  .promo-bar-mobile .promo-message {\n    width: 100%;\n    opacity: 0;\n    visibility: hidden;\n    transition: opacity 0.8s ease-in-out, visibility 0.8s ease-in-out;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    pointer-events: none;\n    position: absolute;\n    top: 0;\n    left: 0;\n  }\n\n  .promo-bar-mobile .promo-message.active {\n    opacity: 1;\n    visibility: visible;\n    pointer-events: auto;\n    position: relative;\n  }\n\n  @media screen and (max-width: 768px) {\n    .promo-bar-desktop {\n      display: none;\n    }\n\n    .promo-bar-mobile {\n      display: block;\n    }\n\n    .promo-bar {\n      padding: 10px 15px;\n      font-size: 11px;\n    }\n  }\n\n  @media screen and (min-width: 769px) {\n    .promo-bar-mobile {\n      display: none;\n    }\n  }\n</style>\n\n<div class=\"promo-bar\">\n  <!-- Desktop View: Show all 3 messages side by side -->\n  <div class=\"promo-bar-desktop\">\n    <div class=\"promo-message\">{{ message1 }}</div>\n    <div class=\"promo-message\">{{ message2 }}</div>\n    <div class=\"promo-message\">{{ message3 }}</div>\n  </div>\n\n  <!-- Mobile View: Rotating messages with fade effect -->\n  <div class=\"promo-bar-mobile\">\n    <div class=\"promo-message active\" data-index=\"0\">{{ message1 }}</div>\n    <div class=\"promo-message\" data-index=\"1\">{{ message2 }}</div>\n    <div class=\"promo-message\" data-index=\"2\">{{ message3 }}</div>\n  </div>\n</div>\n\n<script>\n  (function() {\n    'use strict';\n    \n    function initPromoBarRotation() {\n      const promoBarMobile = document.querySelector('.promo-bar-mobile');\n      if (!promoBarMobile) {\n        setTimeout(initPromoBarRotation, 100);\n        return;\n      }\n      \n      const messages = promoBarMobile.querySelectorAll('.promo-message');\n      if (messages.length === 0) {\n        setTimeout(initPromoBarRotation, 100);\n        return;\n      }\n      \n      let currentIndex = 0;\n      let rotationInterval = null;\n\n      function rotateMessages() {\n        if (messages.length === 0) return;\n        \n        // Remove active class from current message and set to absolute\n        if (messages[currentIndex]) {\n          messages[currentIndex].classList.remove('active');\n          messages[currentIndex].style.position = 'absolute';\n        }\n        \n        // Move to next message\n        currentIndex = (currentIndex + 1) % messages.length;\n        \n        // Add active class to next message and set to relative\n        if (messages[currentIndex]) {\n          messages[currentIndex].classList.add('active');\n          messages[currentIndex].style.position = 'relative';\n        }\n      }\n      \n      // Initialize: set first message to relative, others to absolute\n      function initializeMessages() {\n        messages.forEach(function(msg, index) {\n          if (index === 0 && msg.classList.contains('active')) {\n            msg.style.position = 'relative';\n          } else {\n            msg.style.position = 'absolute';\n          }\n        });\n      }\n      \n      initializeMessages();\n\n      function startRotation() {\n        // Clear any existing interval\n        if (rotationInterval) {\n          clearInterval(rotationInterval);\n          rotationInterval = null;\n        }\n        \n        // Only start if on mobile\n        if (window.innerWidth <= 768 && messages.length > 1) {\n          // Initialize messages position\n          initializeMessages();\n          \n          // Start rotation after 3 seconds, then repeat every 3 seconds\n          setTimeout(function() {\n            rotationInterval = setInterval(function() {\n              rotateMessages();\n            }, 3000);\n          }, 3000);\n        }\n      }\n\n      function stopRotation() {\n        if (rotationInterval) {\n          clearInterval(rotationInterval);\n          rotationInterval = null;\n        }\n      }\n\n      // Handle window resize\n      let resizeTimer;\n      function handleResize() {\n        clearTimeout(resizeTimer);\n        resizeTimer = setTimeout(function() {\n          if (window.innerWidth <= 768) {\n            currentIndex = 0;\n            initializeMessages();\n            startRotation();\n          } else {\n            stopRotation();\n            // Reset to first message\n            messages.forEach(function(msg, index) {\n              if (index === 0) {\n                msg.classList.add('active');\n                msg.style.position = 'relative';\n              } else {\n                msg.classList.remove('active');\n                msg.style.position = 'absolute';\n              }\n            });\n            currentIndex = 0;\n          }\n        }, 250);\n      }\n\n      window.addEventListener('resize', handleResize);\n\n      // Initialize rotation\n      startRotation();\n    }\n\n    // Try multiple ways to ensure script runs\n    if (document.readyState === 'loading') {\n      document.addEventListener('DOMContentLoaded', initPromoBarRotation);\n    } else {\n      // DOM already loaded\n      initPromoBarRotation();\n    }\n    \n    // Fallback: try again after a short delay\n    setTimeout(initPromoBarRotation, 500);\n  })();\n</script>",
