oke-width=\"1\" fill=\"none\"\/>\n            <circle cx=\"9.5\" cy=\"26\" r=\"1\" fill=\"#000\"\/>\n            <circle cx=\"33.5\" cy=\"26\" r=\"1\" fill=\"#000\"\/>\n            <path d=\"M.5 18H2a2.5 2.5 0 0 1 0 5H.5\" stroke=\"#000\" stroke-width=\"1\" fill=\"none\"\/>\n          <\/svg>\n        <\/div>\n        <div class=\"feature-banner__text\">\n          <b>FREE SHIPPING<\/b>\n          <span>On orders over Rs. 2999<\/span>\n        <\/div>\n      <\/div>\n\n      <!-- EXPORT QUALITY -->\n      <div class=\"feature-banner__item\">\n        <div class=\"feature-banner__icon\">\n          <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0555\/2036\/2579\/files\/import.png?v=1765482121\" alt=\"Export Quality\" \/>\n        <\/div>\n        <div class=\"feature-banner__text\">\n          <b>EXPORT QUALITY<\/b>\n          <span>Premium Quality Products<\/span>\n        <\/div>\n      <\/div>\n\n      <!-- RETURNS & EXCHANGE -->\n      <div class=\"feature-banner__item\">\n        <div class=\"feature-banner__icon\">\n          <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0555\/2036\/2579\/files\/return-box.png?v=1765482121\" alt=\"Returns & Exchange\" \/>\n        <\/div>\n        <div class=\"feature-banner__text\">\n          <b>RETURNS & EXCHANGE<\/b>\n          <span>15 Day Return & Money Back<\/span>\n        <\/div>\n      <\/div>\n    <\/div>\n  <\/div>\n<\/body>\n<\/html>"}},"order_Kptzyn":{"type":"order","settings":{"hide_pre":true,"icon":"2","icon_name":"las la-truck","ani":"swing is--infinite","txt":"Order in the next [hour] to get it between [date_start] and [date_end]","ds":0,"de":4,"mode":"1","cut_day":"SAT,SUN","frm_day":"t44, t45 t46","time":"16:00:00","hr":"hours","min":"minutes"}},"description":{"type":"description","disabled":true,"settings":{"des":"2","text":"","length":31,"readm":false,"readm_txt":"Read more"}},"custom_liquid_xYDBqH":{"type":"custom_liquid","settings":{"custom_liquid":"{% if product.metafields.custom.pair_product.value %}\n  {% assign paired_product = product.metafields.custom.pair_product.value %}\n\n  {% assign total_price = product.price | plus: paired_product.price %}\n  {% assign total_compare = 0 %}\n\n  {% if product.compare_at_price > product.price %}\n    {% assign total_compare = product.compare_at_price %}\n  {% endif %}\n  {% if paired_product.compare_at_price > paired_product.price %}\n    {% assign total_compare = total_compare | plus: paired_product.compare_at_price %}\n  {% endif %}\n\n  <div class=\"pair-section\">\n    <h2 class=\"pair-heading\">Pair it with<\/h2>\n\n    <div class=\"pair-row\">\n      <!-- Current Product -->\n      <div class=\"pair-item\">\n        <div class=\"pair-image\">\n          <img\n            src=\"{{ product.featured_image | image_url: width: 800 }}\"\n            alt=\"{{ product.title }}\">\n        <\/div>\n        <p class=\"pair-title\">{{ product.title }}<\/p>\n      <\/div>\n\n      <!-- Plus -->\n      <div class=\"pair-plus\">+<\/div>\n\n      <!-- Paired Product -->\n      <div class=\"pair-item\">\n        <a href=\"{{ paired_product.url }}\" class=\"pair-link\">\n          <div class=\"pair-image\">\n            <img\n              src=\"{{ paired_product.featured_image | image_url: width: 800 }}\"\n              alt=\"{{ paired_product.title }}\">\n          <\/div>\n          <p class=\"pair-title\">{{ paired_product.title }}<\/p>\n        <\/a>\n      <\/div>\n    <\/div>\n\n    <!-- CTA -->\n    <div class=\"pair-cta\">\n      <div class=\"pair-total\">\n        <span class=\"total-label\">Total price:<\/span>\n        {% if total_compare > total_price %}\n          <span class=\"total-compare\">{{ total_compare | money }}<\/span>\n        {% endif %}\n        <span class=\"total-sale\">{{ total_price | money }}<\/span>\n      <\/div>\n\n      <button\n        type=\"button\"\n        class=\"pair-btn js-pair-add\"\n        data-main-variant=\"{{ product.variants.first.id }}\"\n        data-pair-variant=\"{{ paired_product.variants.first.id }}\">\n        ADD SELECTED TO CART\n      <\/button>\n    <\/div>\n  <\/div>\n\n  <style>\n    .pair-section {\n      text-align: center;\n      padding: 20px 0 24px;\n    }\n\n    .pair-heading {\n      font-size: 26px;\n      font-weight: 700;\n      margin-bottom: 18px;\n    }\n\n    .pair-row {\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      gap: 22px;\n    }\n\n    .pair-item {\n      width: 240px;\n    }\n\n    .pair-image {\n      width: 240px;\n      height: 240px;\n      border-radius: 10px;\n      overflow: hidden;\n      background: #f5f5f5;\n    }\n\n    .pair-image img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      display: block;\n    }\n\n    .pair-title {\n      margin-top: 6px;\n      font-weight: 600;\n      font-size: 14px;\n      line-height: 1.35;\n      color: #000;\n    }\n\n    .pair-plus {\n      font-size: 26px;\n      color: #8b5e3c;\n    }\n\n    .pair-cta {\n      margin-top: 6px;\n    }\n\n    .pair-total {\n      margin: 0 0 8px;\n      font-size: 15px;\n    }\n\n    .total-label {\n      margin-right: 6px;\n    }\n\n    .total-compare {\n      margin-right: 6px;\n      color: #777;\n      text-decoration: line-through;\n    }\n\n    .total-sale {\n      color: #d32f2f;\n      font-weight: 700;\n    }\n\n    .pair-btn {\n      background: #000;\n      color: #fff;\n      border: none;\n      padding: 12px 26px;\n      border-radius: 30px;\n      font-weight: 600;\n      cursor: pointer;\n    }\n\n    .pair-btn:hover {\n      opacity: 0.9;\n    }\n\n    .pair-link,\n    .pair-link:hover {\n      text-decoration: none !important;\n      border: none !important;\n      color: inherit;\n      display: block;\n    }\n\n    .pair-link::before,\n    .pair-link::after {\n      display: none !important;\n      content: none !important;\n    }\n\n    @media (max-width: 768px) {\n      .pair-row {\n        gap: 14px;\n      }\n\n      .pair-item {\n        width: 44%;\n      }\n\n      .pair-image {\n        width: 100%;\n        height: auto;\n        aspect-ratio: 1 \/ 1;\n      }\n    }\n  <\/style>\n\n  <script>\n    document.addEventListener('DOMContentLoaded', function () {\n      const btn = document.querySelector('.js-pair-add');\n      if (!btn) return;\n\n      btn.addEventListener('click', function (e) {\n        e.preventDefault();\n        e.stopPropagation();\n\n        const mainVariant = btn.dataset.mainVariant;\n        const pairVariant = btn.dataset.pairVariant;\n\n        fetch('\/cart\/add.js', {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application\/json',\n            'Accept': 'application\/json'\n          },\n          body: JSON.stringify({\n            items: [\n              { id: mainVariant, quantity: 1 },\n              { id: pairVariant, quantity: 1 }\n            ]\n          })\n        })\n        .then(() => {\n          window.location.href = '\/cart';\n        })\n        .catch(err => console.error('Add to cart error:', err));\n      });\n    });\n  <\/script>\n{% endif %}"}},"95d4f334-8ea7-4cd2-b609-2373b1e848b8":{"type":"tab_des","settings":{"title":"Description"}},"tab_html_BMEgt4":{"type":"tab_html","settings":{"title":"Return & Refund","content":"<p>FactoryX.pk gladly accepts returns or exchanges within <strong>15 days of purchase<\/strong>, provided the items are <strong>unworn, unwashed, and have original tags<\/strong>.<br\/><br\/>To request an exchange or refund, please fill out the <strong>exchange\/refund form<\/strong> included with your order and send it back along with the merchandise to our return address.<\/p><ul><li><strong>Return courier charges will be paid by the customer.<\/strong><br\/><\/li><li>Items must be shipped back within <strong>15 days of receiving them<\/strong>; requests after this period will not be accepted.<br\/><\/li><li>Please use a <strong>trackable courier service<\/strong> (courier or regist